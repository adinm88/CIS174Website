@{
}
@model PhoneWebApp.Models.TicketViewModel
<div asp-validation-summary="All" class="text-danger"></div>

<h1>ToDo Tickets</h1>

<p>
    Filter:
    <a asp-action="Index" asp-route-status="All">All</a> |
    <a asp-action="Index" asp-route-status="To Do">To Do</a> |
    <a asp-action="Index" asp-route-status="In Progress">In Progress</a> |
    <a asp-action="Index" asp-route-status="QA">QA</a> |
    <a asp-action="Index" asp-route-status="Done">Done</a>
</p>

<table border="1">
    <tr>
        <th>ID</th>
        <th>Name</th>
        <th>Description</th>
        <th>Sprint</th>
        <th>Points</th>
        <th>Status</th>
    </tr>

    @foreach (var ticket in Model.Tickets)
    {
        <tr>
            <td>@ticket.Id</td>
            <td>@ticket.Name</td>
            <td>@ticket.Description</td>
            <td>@ticket.SprintNumber</td>
            <td>@ticket.PointValue</td>
            <td>@ticket.Status</td>
        </tr>
    }
</table>