@{
}
@model List<PhoneWebApp.Models.OlympicCountry>
@{
    ViewData["Title"] = "Favorite Olympic Countries";
}
<h2>Favorites</h2>

@if (ViewBag.Favorites == null)
{
    <p>No favorites selected.</p>
}
else
{
    string[] items = ViewBag.Favorites.Split(',');
    @foreach (string Favorite in items)
    {
        @foreach (var country in Model)
        {
            @if (Favorite.Equals(country.Country)) {
                <p>@Favorite <img src="~/images/@country.FlagImage" height="50" width="50" /></p>
                <br>
        }

    }
}
    

}
<a asp-controller="Olympic" asp-action="Index">Return to Olympic Team Page</a>

<br>
<br>

<a asp-controller="Favorites" asp-action="Clear">Clear Favorites</a>