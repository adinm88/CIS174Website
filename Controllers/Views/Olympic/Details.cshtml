@{
}
@model PhoneWebApp.Models.OlympicCountry
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
</head>
<body>
    <h1>@Model.Country</h1>

    <img src="/images/@Model.FlagImage" width="200" alt="@Model.Country Flag" />

    <p>Game: @Model.Game</p>
    <p>Sport: @Model.Sport</p>
    <p>Category: @Model.Category</p>

    <a asp-action="Index">Back to Countries</a> <br />


    <a asp-controller="Favorites" asp-action="Add" asp-route-id="@Model.Country">
        Add to Favorites
    </a>
</body>
</html>
